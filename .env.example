# Capital.com MCP Server — copy to .env (or ~/.config/capital-mcp/.env) and fill in.
# You can also run: capitalcom-mcp init

# ---- Environment ----
CAP_ENV=demo                      # demo | live (start with demo)

# ---- Credentials (choose ONE of: literal value, or a *_CMD helper) ----
CAP_API_KEY=ENTER_GENERATED_API_KEY
CAP_IDENTIFIER=ENTER_YOUR_EMAIL
CAP_API_PASSWORD=ENTER_YOUR_API_PASSWORD
# Secret-manager helpers (override .env, never written to disk):
# CAP_API_KEY_CMD=op read op://vault/capitalcom/api-key
# CAP_IDENTIFIER_CMD=pass capitalcom/identifier
# CAP_API_PASSWORD_CMD=pass capitalcom/api-password

# Point at a specific env file (used in client configs to keep secrets out of JSON):
# CAP_ENV_FILE=/home/you/.config/capital-mcp/.env

# ---- Trading safety (defaults are safe: trading OFF) ----
CAP_ALLOW_TRADING=false
CAP_ALLOWED_EPICS=                # e.g. GOLD,SILVER,BTCUSD  or  ALL
CAP_MAX_POSITION_SIZE=1.0
CAP_MAX_WORKING_ORDER_SIZE=1.0
CAP_MAX_OPEN_POSITIONS=3
CAP_MAX_ORDERS_PER_DAY=20
CAP_REQUIRE_EXPLICIT_CONFIRM=true
CAP_DRY_RUN=false

# ---- Session / streaming ----
CAP_PERSIST_SESSION=true          # cache tokens (0600) to avoid HTTP 429 on restart
CAP_WS_ENABLED=false              # enable WebSocket streaming tools
CAP_LOG_LEVEL=INFO

# ---- MCP transport (for remote/VPS hosting) ----
# CAP_MCP_TRANSPORT=http
# CAP_MCP_HOST=0.0.0.0
# CAP_MCP_PORT=8000
